# AutoParkGPT environment configuration (copy to .env and fill in).
# Secrets are injected via the environment ONLY — never commit a real .env.
# Nested settings use the AUTOPARK_ prefix and __ delimiter.

# ----- Application -----
AUTOPARK_APP__ENVIRONMENT=local
AUTOPARK_APP__LOG_LEVEL=INFO
AUTOPARK_APP__LOG_JSON=true
AUTOPARK_APP__PORT=8000

# ----- LLM (Claude via langchain-anthropic) -----
# Tiers: claude-haiku-4-5 ($1/$5) | claude-sonnet-4-6 ($3/$15) | claude-opus-4-8 ($5/$25)
AUTOPARK_LLM__MODEL=claude-haiku-4-5
AUTOPARK_LLM__API_KEY=            # REQUIRED to run the app — your Anthropic API key
AUTOPARK_LLM__MAX_TOKENS=4096
# adaptive | off. Adaptive thinking only applies on Claude 4.6+ models (Opus 4.6/4.7/4.8,
# Sonnet 4.6); it is ignored for the default Haiku 4.5, so the value is safe to leave as-is.
AUTOPARK_LLM__THINKING=off

# ----- Embeddings (Anthropic has no embeddings API) -----
AUTOPARK_EMBEDDING__PROVIDER=huggingface   # huggingface (local, default) | voyage
AUTOPARK_EMBEDDING__HUGGINGFACE_MODEL=BAAI/bge-small-en-v1.5
AUTOPARK_EMBEDDING__DIMENSIONS=384
# Only needed when PROVIDER=voyage:
AUTOPARK_EMBEDDING__VOYAGE_MODEL=voyage-3
AUTOPARK_EMBEDDING__VOYAGE_API_KEY=

# ----- Vector store (Weaviate) -----
AUTOPARK_VECTOR_STORE__HOST=localhost
AUTOPARK_VECTOR_STORE__HTTP_PORT=8080
AUTOPARK_VECTOR_STORE__GRPC_PORT=50051
AUTOPARK_VECTOR_STORE__COLLECTION=ParkingKnowledge

# ----- Retrieval -----
AUTOPARK_RETRIEVAL__TOP_K=4
AUTOPARK_RETRIEVAL__HYBRID_ALPHA=0.5
AUTOPARK_RETRIEVAL__CHUNK_SIZE=512
AUTOPARK_RETRIEVAL__CHUNK_OVERLAP=64

# ----- SQL (PostgreSQL in prod, SQLite for local/tests) -----
# Local default uses SQLite; for the Docker Compose stack use Postgres:
# AUTOPARK_SQL__URL=postgresql+psycopg://autopark:autopark@postgres:5432/autopark
AUTOPARK_SQL__URL=sqlite+pysqlite:///./autoparkgpt.db
AUTOPARK_SQL__ECHO=false

# ----- Guardrails -----
AUTOPARK_GUARDRAIL__MAX_INPUT_CHARS=4000
AUTOPARK_GUARDRAIL__ENABLE_INJECTION_DETECTION=true
AUTOPARK_GUARDRAIL__ENABLE_OUTPUT_LEAKAGE_SCAN=true
